{
  "compilerOptions": {
    "paths": {
      "*": ["./src/*"]
    },
    "inlineSourceMap": true,
    "inlineSources": true,
    "module": "ESNext",
    "target": "ES6",
    "jsx": "react",
    "allowJs": true,
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "importHelpers": true,
    "isolatedModules": true,
    "strictNullChecks": true,
    "allowSyntheticDefaultImports": true,
    "lib": ["DOM", "ES5", "ES6", "ES7", "ES2017"],
    "types": ["@testing-library/jest-dom"]
  },
  "include": ["**/*.ts", "**/*.tsx"]
}
